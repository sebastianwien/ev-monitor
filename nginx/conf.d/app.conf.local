# Local Development - HTTP only on port 80
# This mimics the production setup without SSL

map $http_user_agent $is_bot {
    default 0;
    "~*googlebot"               1;
    "~*google-inspectiontool"   1;
    "~*google-extended"         1;
    "~*bingbot"                 1;
    "~*yandexbot"               1;
    "~*duckduckbot"             1;
    "~*slurp"                   1;
    "~*facebookexternalhit"     1;
    "~*twitterbot"              1;
    "~*linkedinbot"             1;
    "~*whatsapp"                1;
    "~*perplexitybot"           1;
    "~*claudebot"               1;
    "~*anthropic-ai"            1;
    "~*gptbot"                  1;
    "~*chatgpt-user"            1;
    "~*oai-searchbot"           1;
    "~*cohere-ai"               1;
    "~*applebot"                1;
    "~*ahrefsbot"               1;
    "~*semrushbot"              1;
}

server {
    listen 80;
    server_name localhost;
    server_tokens off;

    # Prerender for bots on public SEO pages (all markets)
    location ~* ^/(modelle|en|gb|us|no|se) {
        resolver 127.0.0.11 valid=10s;
        set $prerender 0;
        if ($is_bot = 1) {
            set $prerender 1;
        }
        set $prerender_url "http://prerender:3000/http://nginx$request_uri";
        if ($prerender = 1) {
            access_log /var/log/nginx/prerender.log prerender;
            proxy_pass $prerender_url;
        }
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # Serve Frontend PWA (with Prerender for bots on landing page)
    location = / {
        resolver 127.0.0.11 valid=10s;
        set $prerender 0;
        if ($is_bot = 1) {
            set $prerender 1;
        }
        set $prerender_url "http://prerender:3000/http://nginx/";
        if ($prerender = 1) {
            access_log /var/log/nginx/prerender.log prerender;
            proxy_pass $prerender_url;
        }
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    location = /sitemap.xml {
        proxy_pass http://backend:8080/sitemap.xml;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # Proxy API requests to backend
    location /api/ {
        proxy_pass http://backend:8080/api/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_buffering off;
    }

    # Proxy Wallbox REST API
    location /api/wallbox/ {
        proxy_pass http://wallbox-service:8090/api/wallbox/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_buffering off;
    }

    # Proxy OCPP WebSocket to wallbox-service (OCPP 1.6 runs on port 9090, not 8090)
    location /ocpp/ws/ {
        proxy_pass http://wallbox-service:9090/ocpp/ws/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # Proxy OAuth2 requests to backend (optional, for future use)
    location /oauth2/ {
        proxy_pass http://backend:8080/oauth2/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /login/oauth2/ {
        proxy_pass http://backend:8080/login/oauth2/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
