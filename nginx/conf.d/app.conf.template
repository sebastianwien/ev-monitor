# HTTP - Redirect to HTTPS
server {
    listen 80;
    server_name ${DOMAIN};
    server_tokens off;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

map $http_user_agent $is_bot {
    default 0;
    "~*googlebot"               1;
    "~*google-inspectiontool"   1;
    "~*google-extended"         1;
    "~*bingbot"                 1;
    "~*yandexbot"               1;
    "~*duckduckbot"             1;
    "~*slurp"                   1;
    "~*facebookexternalhit"     1;
    "~*twitterbot"              1;
    "~*linkedinbot"             1;
    "~*whatsapp"                1;
    "~*perplexitybot"           1;
    "~*claudebot"               1;
    "~*anthropic-ai"            1;
    "~*gptbot"                  1;
    "~*chatgpt-user"            1;
    "~*oai-searchbot"           1;
    "~*cohere-ai"               1;
    "~*applebot"                1;
    "~*ahrefsbot"               1;
    "~*semrushbot"              1;
}

# HTTPS
server {
    listen 443 ssl http2;
    server_name ${DOMAIN};
    server_tokens off;

    client_max_body_size 5m;

    ssl_certificate /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;

    # SSL Configuration (Mozilla Intermediate)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # Security Headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Note: Using static hostnames instead of variables for reliable URI path handling
    # nginx reloads automatically after container restarts via deploy.sh

    # Tesla Fleet API public key (required for partner registration)
    location /.well-known/appspecific/ {
        alias /usr/share/nginx/well-known/appspecific/;
        add_header Content-Type text/plain;
    }

    # Prerender for bots on public SEO pages
    location ~* ^/modelle {
        resolver 127.0.0.11 valid=10s;
        set $prerender 0;
        if ($is_bot = 1) {
            set $prerender 1;
        }
        set $prerender_url "http://prerender:3000/https://ev-monitor.net$request_uri";
        if ($prerender = 1) {
            access_log /var/log/nginx/prerender.log prerender;
            proxy_pass $prerender_url;
        }
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # Serve Frontend PWA (with Prerender for bots on landing page)
    location = / {
        resolver 127.0.0.11 valid=10s;
        set $prerender 0;
        if ($is_bot = 1) {
            set $prerender 1;
        }
        set $prerender_url "http://prerender:3000/https://ev-monitor.net/";
        if ($prerender = 1) {
            access_log /var/log/nginx/prerender.log prerender;
            proxy_pass $prerender_url;
        }
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    location / {
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # Proxy Connectors Service (Tesla Fleet + go-eCharger Cloud)
    # Must appear before the generic /api/ block to take precedence

    location /api/tesla/ {
        proxy_pass http://connectors-service:8081/api/tesla/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_buffering off;
    }

    location /api/goe/ {
        proxy_pass http://connectors-service:8081/api/goe/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_buffering off;
    }

    # Swagger UI + OpenAPI docs
    location /swagger-ui/ {
        proxy_pass http://backend:8080/swagger-ui/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /v3/api-docs {
        proxy_pass http://backend:8080/v3/api-docs;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Proxy API requests to backend (must come after specific /api/ blocks)
    location /api/ {
        proxy_pass http://backend:8080/api/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_buffering off;
    }

    # Proxy Wallbox REST API
    location /api/wallbox/ {
        proxy_pass http://wallbox-service:8090/api/wallbox/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_buffering off;
    }

    # Proxy OCPP WebSocket to wallbox-service
    location /ocpp/ws/ {
        proxy_pass http://wallbox-service:8090/ocpp/ws/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # Proxy OAuth2 requests to backend
    location /oauth2/ {
        proxy_pass http://backend:8080/oauth2/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /login/oauth2/ {
        proxy_pass http://backend:8080/login/oauth2/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
